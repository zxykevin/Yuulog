---
const API_BASE_URL =
	import.meta.env.PUBLIC_COMMENTS_API_BASE_URL ??
	"https://comments.yuulog.org";
const TURNSTILE_SITE_KEY = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? "";
---

<section
	class="comment-section mb-4"
	data-comment-box
	data-api-base-url={API_BASE_URL}
	data-turnstile-site-key={TURNSTILE_SITE_KEY}
	aria-label="评论区"
>
	<div class="comment-section-header">
		<h2>评论</h2>
		<span data-comment-count aria-live="polite"></span>
	</div>

	<div class="comment-list" data-comment-list aria-live="polite">
		<div class="comment-state-card">
			<p class="comment-state-text">评论加载中...</p>
		</div>
	</div>

	<form class="comment-form-card" data-comment-form novalidate>
		<div class="comment-form-heading">
			<h3 data-form-title>发表评论</h3>
			<button type="button" data-cancel-reply hidden>取消回复</button>
		</div>
		<div class="comment-form-grid">
			<label>
				<span>昵称</span>
				<input name="nickname" type="text" required maxlength="30" />
			</label>
			<label>
				<span>邮箱</span>
				<input name="email" type="email" maxlength="160" />
			</label>
			<label>
				<span>网站</span>
				<input
					name="website"
					type="url"
					placeholder="https://example.com"
					maxlength="240"
				/>
			</label>
		</div>

		<label>
			<span>评论内容</span>
			<textarea name="content" required rows="5" maxlength="1000"
			></textarea>
		</label>

		<div class="comment-turnstile" data-turnstile-slot hidden></div>

		<div class="comment-form-footer">
			<p
				class="comment-feedback"
				data-comment-feedback
				aria-live="polite"
			>
			</p>
			<button type="submit" data-submit-button>提交评论</button>
		</div>
	</form>
</section>

<script>
	const COMMENT_RENDER_ASSETS = {
		marked: "https://cdn.jsdelivr.net/npm/marked@12.0.2/marked.min.js",
		dompurify:
			"https://cdn.jsdelivr.net/npm/dompurify@3.1.6/dist/purify.min.js",
	};
	const COMMENT_LINK_REL = "nofollow noopener noreferrer";
	const REPORT_REASONS = [
		["spam", "垃圾广告"],
		["abuse", "辱骂攻击"],
		["harassment", "骚扰"],
		["privacy", "隐私泄露"],
		["illegal", "违法内容"],
		["other", "其他"],
	] as const;
	const EMAIL_PATTERN = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
	let deviceFingerprintPromise: Promise<string | null> | undefined;

	type Comment = {
		id: string;
		pagePath: string;
		parentId: string | null;
		nickname: string;
		website: string | null;
		content: string;
		createdAt: string;
		likeCount?: number;
		liked?: boolean;
	};

	type CommentsResponse = {
		ok: boolean;
		comments?: Comment[];
		message?: string;
	};

	type SubmitResponse = {
		ok: boolean;
		status?: string;
		message?: string;
	};

	type CommentBoxElement = HTMLElement & {
		dataset: DOMStringMap & {
			commentReady?: string;
			apiBaseUrl?: string;
			turnstileSiteKey?: string;
		};
		__turnstileToken?: string;
		__turnstileWidgetId?: string;
		__replyTarget?: {
			id: string;
			nickname: string;
		} | null;
	};

	type TurnstileApi = {
		render: (
			container: HTMLElement,
			options: {
				sitekey: string;
				callback: (token: string) => void;
				"expired-callback": () => void;
				"error-callback": () => void;
			},
		) => string;
		reset: (widgetId?: string) => void;
	};

	type TurnstileWindow = Window &
		typeof globalThis & {
			turnstile?: TurnstileApi;
			__mizukiTurnstileLoader?: Promise<TurnstileApi>;
			__mizukiCommentScriptLoaders?: Partial<Record<string, Promise<void>>>;
			marked?: {
				parse: (
					content: string,
					options?: Record<string, unknown>,
				) => string;
			};
			DOMPurify?: {
				sanitize: (
					content: string,
					options?: Record<string, unknown>,
				) => string;
			};
		};

	function isHttpWebsite(value: string) {
		if (!value) return true;
		try {
			const url = new URL(value);
			return url.protocol === "http:" || url.protocol === "https:";
		} catch {
			return false;
		}
	}

	function getSafeWebsite(value: string | null) {
		return value && isHttpWebsite(value) ? value : null;
	}

	function isValidEmail(value: string) {
		return EMAIL_PATTERN.test(value);
	}

	async function getDeviceFingerprint() {
		if (!deviceFingerprintPromise) {
			deviceFingerprintPromise = (async () => {
				if (!window.crypto?.subtle) return null;
				const source = [
					navigator.userAgent,
					navigator.language,
					screen.width,
					screen.height,
					screen.colorDepth,
					Intl.DateTimeFormat().resolvedOptions().timeZone,
				].join("|");
				const digest = await crypto.subtle.digest(
					"SHA-256",
					new TextEncoder().encode(source),
				);
				return Array.from(new Uint8Array(digest), (byte) =>
					byte.toString(16).padStart(2, "0"),
				).join("");
			})().catch(() => null);
		}

		return deviceFingerprintPromise;
	}

	function formatLocalTime(value: string) {
		const date = new Date(value);
		return Number.isNaN(date.getTime())
			? value
			: date.toLocaleString(undefined, {
					year: "numeric",
					month: "2-digit",
					day: "2-digit",
					hour: "2-digit",
					minute: "2-digit",
				});
	}

	function getElements(root: CommentBoxElement) {
		return {
			list: root.querySelector<HTMLElement>("[data-comment-list]"),
			count: root.querySelector<HTMLElement>("[data-comment-count]"),
			form: root.querySelector<HTMLFormElement>("[data-comment-form]"),
			formTitle: root.querySelector<HTMLElement>("[data-form-title]"),
			cancelReplyButton: root.querySelector<HTMLButtonElement>(
				"[data-cancel-reply]",
			),
			feedback: root.querySelector<HTMLElement>(
				"[data-comment-feedback]",
			),
			submitButton: root.querySelector<HTMLButtonElement>(
				"[data-submit-button]",
			),
			turnstileSlot: root.querySelector<HTMLElement>(
				"[data-turnstile-slot]",
			),
		};
	}

	function loadTurnstileScript() {
		const turnstileWindow = window as TurnstileWindow;
		if (turnstileWindow.turnstile) {
			return Promise.resolve(turnstileWindow.turnstile);
		}
		if (turnstileWindow.__mizukiTurnstileLoader) {
			return turnstileWindow.__mizukiTurnstileLoader;
		}

		turnstileWindow.__mizukiTurnstileLoader = new Promise(
			(resolve, reject) => {
				const existingScript =
					document.querySelector<HTMLScriptElement>(
						'script[data-turnstile-script="true"]',
					);
				const script =
					existingScript ?? document.createElement("script");

				const handleLoad = () => {
					if (turnstileWindow.turnstile) {
						resolve(turnstileWindow.turnstile);
						return;
					}
					reject(new Error("Turnstile API unavailable"));
				};

				script.addEventListener("load", handleLoad, { once: true });
				script.addEventListener(
					"error",
					() => reject(new Error("Turnstile script failed to load")),
					{ once: true },
				);

				if (!existingScript) {
					script.src =
						"https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit";
					script.async = true;
					script.defer = true;
					script.dataset.turnstileScript = "true";
					document.head.append(script);
				}
			},
		);

		return turnstileWindow.__mizukiTurnstileLoader;
	}

	function loadScriptOnce(
		id: string,
		src: string,
		isReady: (win: TurnstileWindow) => boolean,
	) {
		const browserWindow = window as TurnstileWindow;
		if (isReady(browserWindow)) return Promise.resolve();
		if (!browserWindow.__mizukiCommentScriptLoaders) {
			browserWindow.__mizukiCommentScriptLoaders = {};
		}
		if (browserWindow.__mizukiCommentScriptLoaders[id]) {
			return browserWindow.__mizukiCommentScriptLoaders[id];
		}

		browserWindow.__mizukiCommentScriptLoaders[id] = new Promise(
			(resolve, reject) => {
				const existingScript =
					document.querySelector<HTMLScriptElement>(
						`script[data-comment-lib="${id}"]`,
					);
				const script =
					existingScript ?? document.createElement("script");

				script.addEventListener(
					"load",
					() =>
						isReady(browserWindow)
							? resolve()
							: reject(new Error(`${id} unavailable`)),
					{ once: true },
				);
				script.addEventListener(
					"error",
					() => reject(new Error(`${id} failed to load`)),
					{ once: true },
				);

				if (!existingScript) {
					script.src = src;
					script.async = true;
					script.defer = true;
					script.dataset.commentLib = id;
					document.head.append(script);
				}
			},
		);

		return browserWindow.__mizukiCommentScriptLoaders[id];
	}

	async function prepareCommentRendering() {
		const browserWindow = window as TurnstileWindow;
		try {
			await Promise.all([
				loadScriptOnce(
					"marked",
					COMMENT_RENDER_ASSETS.marked,
					(win) => Boolean(win.marked),
				),
				loadScriptOnce(
					"dompurify",
					COMMENT_RENDER_ASSETS.dompurify,
					(win) => Boolean(win.DOMPurify),
				),
			]);
		} catch (error) {
			console.warn("评论 Markdown 渲染依赖加载失败", error);
		}
		return Boolean(browserWindow.marked && browserWindow.DOMPurify);
	}

	function escapeHtml(value: string) {
		return value.replaceAll("&", "&amp;").replaceAll("<", "&lt;");
	}

	function sanitizeCommentHtml(html: string) {
		const browserWindow = window as TurnstileWindow;
		return browserWindow.DOMPurify?.sanitize(html, {
			ALLOWED_URI_REGEXP:
				/^(?:(?:https?|mailto):|[^a-z]|[a-z+.-]+(?:[^a-z+.-:]|$))/i,
			FORBID_TAGS: [
				"style",
				"script",
				"iframe",
				"object",
				"embed",
				"form",
				"input",
			],
			FORBID_ATTR: ["style", "onerror", "onload", "onclick"],
		}) ?? "";
	}

	function hardenCommentLinks(container: HTMLElement) {
		for (const link of container.querySelectorAll<HTMLAnchorElement>("a[href]")) {
			let url: URL;
			try {
				url = new URL(link.getAttribute("href") ?? "", window.location.href);
			} catch {
				link.removeAttribute("href");
				continue;
			}
			if (!["http:", "https:", "mailto:"].includes(url.protocol)) {
				link.removeAttribute("href");
				continue;
			}
			link.target = "_blank";
			link.rel = COMMENT_LINK_REL;
		}
	}

	function renderCommentContent(container: HTMLElement, content: string) {
		const browserWindow = window as TurnstileWindow;
		container.className = "comment-content";

		if (!browserWindow.marked || !browserWindow.DOMPurify) {
			container.textContent = content;
			return;
		}

		container.classList.add("comment-markdown");
		try {
			const html = browserWindow.marked.parse(escapeHtml(content), {
				gfm: true,
				breaks: true,
				headerIds: false,
				mangle: false,
			});
			container.innerHTML = sanitizeCommentHtml(html);
			hardenCommentLinks(container);
		} catch (error) {
			console.warn("评论 Markdown 渲染失败", error);
			container.textContent = content;
		}
	}

	function renderState(container: HTMLElement, message: string) {
		container.replaceChildren();
		const stateCard = document.createElement("div");
		stateCard.className = "comment-state-card";

		const stateText = document.createElement("p");
		stateText.className = "comment-state-text";
		stateText.textContent = message;

		stateCard.append(stateText);
		container.append(stateCard);
	}

	function normalizeCommentLikeState(comment: Comment) {
		const likeCount = Number(comment.likeCount);
		comment.likeCount =
			Number.isFinite(likeCount) && likeCount > 0 ? likeCount : 0;
		comment.liked = comment.liked === true;
	}

	function updateLikeButton(button: HTMLButtonElement, comment: Comment) {
		normalizeCommentLikeState(comment);
		button.classList.toggle("is-liked", comment.liked === true);
		button.setAttribute("aria-pressed", comment.liked ? "true" : "false");
		button.textContent = comment.liked
			? `♥ 已赞 ${comment.likeCount}`
			: `♥ 赞 ${comment.likeCount}`;
	}

	function renderComments(root: CommentBoxElement, comments: Comment[]) {
		const { list, count } = getElements(root);
		if (!list) return;

		list.replaceChildren();
		if (count)
			count.textContent =
				comments.length > 0 ? `${comments.length} 条` : "";

		if (comments.length === 0) {
			renderState(list, "还没有评论，来留下第一条吧。");
			return;
		}

		const commentsById = new Map(
			comments.map((comment) => [comment.id, comment]),
		);
		const topLevelComments = comments.filter((comment) => !comment.parentId);
		const repliesByParentId = new Map<string, Comment[]>();
		for (const comment of comments) {
			if (!comment.parentId) continue;
			const replies = repliesByParentId.get(comment.parentId) ?? [];
			replies.push(comment);
			repliesByParentId.set(comment.parentId, replies);
		}

		for (const comment of topLevelComments) {
			const article = createCommentArticle(
				root,
				comment,
				commentsById,
			);
			const replies = article.querySelector<HTMLElement>(".comment-replies");
			appendReplies(root, comment.id, replies, repliesByParentId, commentsById);
			list.append(article);
		}
	}

	function appendReplies(
		root: CommentBoxElement,
		parentId: string,
		container: HTMLElement | null,
		repliesByParentId: Map<string, Comment[]>,
		commentsById: Map<string, Comment>,
	) {
		if (!container) return;

		for (const reply of repliesByParentId.get(parentId) ?? []) {
			const article = createCommentArticle(root, reply, commentsById);
			const nestedReplies =
				article.querySelector<HTMLElement>(".comment-replies");
			appendReplies(
				root,
				reply.id,
				nestedReplies,
				repliesByParentId,
				commentsById,
			);
			container.append(article);
		}
	}

	function createCommentArticle(
		root: CommentBoxElement,
		comment: Comment,
		commentsById: Map<string, Comment>,
	) {
		const article = document.createElement("article");
		article.className = "comment-thread-card";
		article.dataset.commentId = comment.id;
		article.dataset.parentId = comment.parentId ?? "";

		const meta = document.createElement("div");
		meta.className = "comment-meta";

		const safeWebsite = getSafeWebsite(comment.website);
		const author = safeWebsite
			? document.createElement("a")
			: document.createElement("span");
		const parentComment = comment.parentId
			? commentsById.get(comment.parentId)
			: null;
		author.className = "comment-author";
		author.textContent = parentComment
			? `回复 @${parentComment.nickname}`
			: comment.nickname;
		if (author instanceof HTMLAnchorElement && safeWebsite) {
			author.href = safeWebsite;
			author.target = "_blank";
			author.rel = "nofollow noopener noreferrer";
		}

		const time = document.createElement("time");
		time.dateTime = comment.createdAt;
		time.textContent = formatLocalTime(comment.createdAt);
		meta.append(author, time);

		const content = document.createElement("div");
		renderCommentContent(content, comment.content);

		const actions = document.createElement("div");
		actions.className = "comment-actions";
		const likeButton = document.createElement("button");
		likeButton.type = "button";
		likeButton.className = "comment-like-button";
		updateLikeButton(likeButton, comment);
		likeButton.addEventListener("click", () => {
			void toggleCommentLike(root, comment, likeButton);
		});
		const replyButton = document.createElement("button");
		replyButton.type = "button";
		replyButton.className = "comment-reply-button";
		replyButton.textContent = "回复";
		replyButton.addEventListener("click", () => {
			setReplyTarget(root, {
				id: comment.id,
				nickname: comment.nickname,
			});
		});
		const reportButton = document.createElement("button");
		reportButton.type = "button";
		reportButton.className = "comment-report-button";
		reportButton.textContent = "举报";
		reportButton.setAttribute("aria-expanded", "false");
		const reportContainer = document.createElement("div");
		reportContainer.className = "comment-report-container";
		reportButton.addEventListener("click", () => {
			toggleReportForm(root, comment, reportContainer, reportButton);
		});
		actions.append(likeButton, replyButton, reportButton);

		const replies = document.createElement("div");
		replies.className = "comment-replies";

		article.append(meta, content, actions, reportContainer, replies);
		return article;
	}

	function toggleReportForm(
		root: CommentBoxElement,
		comment: Comment,
		container: HTMLElement,
		button: HTMLButtonElement,
	) {
		if (container.firstChild) {
			container.replaceChildren();
			button.setAttribute("aria-expanded", "false");
			return;
		}

		container.append(
			createReportForm(root, comment, () => {
				container.replaceChildren();
				button.setAttribute("aria-expanded", "false");
			}),
		);
		button.setAttribute("aria-expanded", "true");
	}

	function createReportForm(
		root: CommentBoxElement,
		comment: Comment,
		onCancel: () => void,
	) {
		const form = document.createElement("form");
		form.className = "comment-report-form";
		form.noValidate = true;

		const emailLabel = document.createElement("label");
		const emailText = document.createElement("span");
		emailText.textContent = "你的邮箱";
		const emailInput = document.createElement("input");
		emailInput.name = "email";
		emailInput.type = "email";
		emailInput.required = true;
		emailInput.maxLength = 254;
		emailInput.placeholder = "you@example.com";
		emailLabel.append(emailText, emailInput);

		const privacyNote = document.createElement("p");
		privacyNote.className = "comment-report-note";
		privacyNote.textContent =
			"你的邮箱会显示给站点管理员，用于处理举报。";

		const reasonLabel = document.createElement("label");
		const reasonText = document.createElement("span");
		reasonText.textContent = "举报原因";
		const reasonSelect = document.createElement("select");
		reasonSelect.name = "reason";
		reasonSelect.required = true;
		for (const [value, label] of REPORT_REASONS) {
			const option = document.createElement("option");
			option.value = value;
			option.textContent = label;
			reasonSelect.append(option);
		}
		reasonLabel.append(reasonText, reasonSelect);

		const messageLabel = document.createElement("label");
		const messageText = document.createElement("span");
		messageText.textContent = "补充说明，可选";
		const messageInput = document.createElement("textarea");
		messageInput.name = "message";
		messageInput.rows = 3;
		messageInput.maxLength = 500;
		messageInput.placeholder = "补充说明，可选";
		messageLabel.append(messageText, messageInput);

		const feedback = document.createElement("p");
		feedback.className = "comment-report-feedback";
		feedback.setAttribute("aria-live", "polite");

		const actions = document.createElement("div");
		actions.className = "comment-report-actions";
		const submitButton = document.createElement("button");
		submitButton.type = "submit";
		submitButton.textContent = "提交举报";
		const cancelButton = document.createElement("button");
		cancelButton.type = "button";
		cancelButton.textContent = "取消";
		cancelButton.addEventListener("click", onCancel);
		actions.append(submitButton, cancelButton);

		form.append(
			emailLabel,
			privacyNote,
			reasonLabel,
			messageLabel,
			feedback,
			actions,
		);
		form.addEventListener("submit", (event) => {
			event.preventDefault();
			void submitCommentReport(root, comment, {
				emailInput,
				reasonSelect,
				messageInput,
				feedback,
				submitButton,
			});
		});

		return form;
	}

	async function submitCommentReport(
		root: CommentBoxElement,
		comment: Comment,
		elements: {
			emailInput: HTMLInputElement;
			reasonSelect: HTMLSelectElement;
			messageInput: HTMLTextAreaElement;
			feedback: HTMLElement;
			submitButton: HTMLButtonElement;
		},
	) {
		const email = elements.emailInput.value.trim();
		const reason = elements.reasonSelect.value;
		const message = elements.messageInput.value.trim();

		elements.feedback.textContent = "";
		if (!isValidEmail(email)) {
			elements.feedback.textContent = "请输入有效的邮箱地址。";
			return;
		}

		elements.submitButton.disabled = true;
		try {
			const response = await fetch(
				`${root.dataset.apiBaseUrl ?? ""}/api/comments/${encodeURIComponent(comment.id)}/report`,
				{
					method: "POST",
					headers: {
						"Content-Type": "application/json",
						Accept: "application/json",
					},
					body: JSON.stringify({
						email,
						reason,
						message: message || null,
					}),
				},
			);
			const data = (await response.json()) as {
				ok?: boolean;
				alreadyReported?: boolean;
				movedToPending?: boolean;
				message?: string;
			};
			if (!response.ok || !data.ok) {
				throw new Error(data.message || "举报提交失败。");
			}

			if (data.alreadyReported === true) {
				elements.feedback.textContent = "你已经举报过这条评论。";
				return;
			}

			elements.feedback.textContent =
				data.movedToPending === true
					? "举报已提交。这条评论已因多次举报被转回待审核状态。"
					: "举报已提交。";
		} catch {
			elements.feedback.textContent = "举报提交失败。";
		} finally {
			elements.submitButton.disabled = false;
		}
	}

	async function toggleCommentLike(
		root: CommentBoxElement,
		comment: Comment,
		button: HTMLButtonElement,
	) {
		const liked = comment.liked === true;
		button.disabled = true;

		try {
			const response = await fetch(
				`${root.dataset.apiBaseUrl ?? ""}/api/comments/${encodeURIComponent(comment.id)}/like`,
				{
					method: liked ? "DELETE" : "POST",
					headers: { Accept: "application/json" },
				},
			);
			const data = (await response.json()) as {
				ok?: boolean;
				likeCount?: number;
				liked?: boolean;
				message?: string;
			};
			if (!response.ok || !data.ok) {
				throw new Error(data.message || "Failed to update like");
			}

			comment.likeCount = Number(data.likeCount) || 0;
			comment.liked = data.liked === true;
			updateLikeButton(button, comment);
		} catch (error) {
			console.warn("评论点赞操作失败", error);
		} finally {
			button.disabled = false;
		}
	}

	async function loadComments(root: CommentBoxElement) {
		const { list } = getElements(root);
		if (!list) return;

		const pagePath = window.location.pathname;
		const apiBaseUrl = root.dataset.apiBaseUrl ?? "";
		renderState(list, "评论加载中...");

		try {
			const response = await fetch(
				`${apiBaseUrl}/api/comments?path=${encodeURIComponent(pagePath)}`,
				{ headers: { Accept: "application/json" } },
			);
			const data = (await response.json()) as CommentsResponse;
			if (!response.ok || !data.ok || !Array.isArray(data.comments)) {
				throw new Error("Failed to load comments");
			}
			await prepareCommentRendering();
			renderComments(root, data.comments);
		} catch {
			renderState(list, "评论加载失败，请稍后再试。");
		}
	}

	function resetTurnstile(root: CommentBoxElement) {
		root.__turnstileToken = "";
		const turnstileWindow = window as TurnstileWindow;
		if (root.__turnstileWidgetId && turnstileWindow.turnstile) {
			turnstileWindow.turnstile.reset(root.__turnstileWidgetId);
		}
	}

	async function setupTurnstile(root: CommentBoxElement) {
		const { turnstileSlot, feedback, submitButton } = getElements(root);
		if (!turnstileSlot || !feedback || !submitButton) return;

		const siteKey = root.dataset.turnstileSiteKey;
		if (!siteKey) {
			feedback.textContent = "评论验证未配置，暂时无法提交评论。";
			submitButton.disabled = true;
			return;
		}

		turnstileSlot.hidden = false;
		try {
			const turnstile = await loadTurnstileScript();
			if (root.__turnstileWidgetId) return;

			root.__turnstileWidgetId = turnstile.render(turnstileSlot, {
				sitekey: siteKey,
				callback: (token) => {
					root.__turnstileToken = token;
					if (feedback.textContent === "请先完成人机验证。") {
						feedback.textContent = "";
					}
				},
				"expired-callback": () => {
					root.__turnstileToken = "";
				},
				"error-callback": () => {
					root.__turnstileToken = "";
					feedback.textContent = "人机验证加载失败，请稍后重试。";
				},
			});
		} catch {
			feedback.textContent = "人机验证加载失败，请稍后重试。";
			submitButton.disabled = true;
		}
	}

	function setupForm(root: CommentBoxElement) {
		const { form, feedback, submitButton, cancelReplyButton } =
			getElements(root);
		if (!form || !feedback || !submitButton) return;

		cancelReplyButton?.addEventListener("click", () => {
			setReplyTarget(root, null);
		});

		form.addEventListener("submit", async (event) => {
			event.preventDefault();
			feedback.textContent = "";

			const formData = new FormData(form);
			const nickname = String(formData.get("nickname") ?? "").trim();
			const email = String(formData.get("email") ?? "").trim();
			const website = String(formData.get("website") ?? "").trim();
			const content = String(formData.get("content") ?? "").trim();

			if (!nickname || !content) {
				feedback.textContent = "请填写昵称和评论内容。";
				return;
			}
			if (!isHttpWebsite(website)) {
				feedback.textContent =
					"网站地址必须以 http:// 或 https:// 开头。";
				return;
			}
			if (!root.__turnstileToken) {
				feedback.textContent = "请先完成人机验证。";
				return;
			}

			submitButton.disabled = true;
			submitButton.textContent = "提交中...";

			try {
				const deviceFingerprint = await getDeviceFingerprint();
				const response = await fetch(
					`${root.dataset.apiBaseUrl ?? ""}/api/comments`,
					{
						method: "POST",
						headers: {
							"Content-Type": "application/json",
							Accept: "application/json",
						},
						body: JSON.stringify({
							pagePath: window.location.pathname,
							parentId: root.__replyTarget?.id ?? null,
							nickname,
							email,
							website,
							content,
							turnstileToken: root.__turnstileToken,
							deviceFingerprint,
						}),
					},
				);
				const data = (await response.json()) as SubmitResponse;
				if (!response.ok || !data.ok) {
					feedback.textContent =
						response.status === 403
							? "评论提交失败：该来源已被封禁。"
							: data.message || "评论提交失败，请稍后再试。";
					return;
				}

				const isApproved = data.status === "approved";
				feedback.textContent = isApproved
					? "评论已发布。"
					: data.message || "评论已提交，等待审核。";
				const contentField = form.elements.namedItem("content");
				if (contentField instanceof HTMLTextAreaElement) {
					contentField.value = "";
				}
				setReplyTarget(root, null);
				if (isApproved) {
					await loadComments(root);
				}
			} catch {
				feedback.textContent = "提交失败，请检查网络后重试。";
			} finally {
				resetTurnstile(root);
				submitButton.disabled = false;
				submitButton.textContent = "提交评论";
			}
		});
	}

	function setReplyTarget(
		root: CommentBoxElement,
		target: CommentBoxElement["__replyTarget"],
	) {
		const { formTitle, cancelReplyButton, form } = getElements(root);
		root.__replyTarget = target;
		if (formTitle) {
			formTitle.textContent = target
				? `回复 @${target.nickname}`
				: "发表评论";
		}
		if (cancelReplyButton) {
			cancelReplyButton.hidden = !target;
		}
		if (target) {
			form?.scrollIntoView({ behavior: "smooth", block: "start" });
		}
	}

	function initCommentBoxes() {
		document
			.querySelectorAll<CommentBoxElement>("[data-comment-box]")
			.forEach((root) => {
				if (root.dataset.commentReady === "true") {
					loadComments(root);
					return;
				}
				root.dataset.commentReady = "true";
				void setupTurnstile(root);
				setupForm(root);
				loadComments(root);
			});
	}

	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", initCommentBoxes, {
			once: true,
		});
	} else {
		initCommentBoxes();
	}
	document.addEventListener("astro:page-load", initCommentBoxes);
	document.addEventListener("mizuki:page:loaded", initCommentBoxes);
</script>

