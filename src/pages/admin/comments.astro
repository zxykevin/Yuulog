---
import AdminCommentsPanel from "@components/admin/AdminCommentsPanel.svelte";
import AdminLayout from "@layouts/AdminLayout.astro";

const API_BASE_URL =
	import.meta.env.PUBLIC_COMMENTS_API_BASE_URL ??
	"https://comments.yuulog.org";
---

<AdminLayout title="评论审核">
	<AdminCommentsPanel client:load apiBaseUrl={API_BASE_URL} />
</AdminLayout>
