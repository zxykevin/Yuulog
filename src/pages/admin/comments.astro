---
import MainGridLayout from "@layouts/MainGridLayout.astro";

const API_BASE_URL =
	import.meta.env.PUBLIC_COMMENTS_API_BASE_URL ??
	"https://comments.yuulog.org";
---

<MainGridLayout title="评论审核">
	<section class="admin-comments-page" data-admin-comments data-api-base-url={API_BASE_URL}>
		<header class="admin-header">
			<div>
				<p class="admin-kicker">Admin</p>
				<h1>评论审核</h1>
			</div>
		</header>

		<form class="token-panel" data-token-form>
			<label for="admin-token">ADMIN_TOKEN</label>
			<div class="token-row">
				<input
					id="admin-token"
					name="token"
					type="password"
					autocomplete="off"
					placeholder="输入 ADMIN_TOKEN"
					data-token-input
				/>
				<button type="submit">保存</button>
			</div>
		</form>

		<div class="filter-row" role="tablist" aria-label="评论状态筛选">
			<button type="button" data-status-filter="" class="is-active">全部</button>
			<button type="button" data-status-filter="pending">pending</button>
			<button type="button" data-status-filter="approved">approved</button>
			<button type="button" data-status-filter="spam">spam</button>
			<button type="button" data-status-filter="deleted">deleted</button>
		</div>

		<p class="feedback" data-feedback aria-live="polite"></p>
		<div class="comment-grid" data-comment-grid aria-live="polite"></div>
	</section>
</MainGridLayout>

<script>
	type CommentStatus = "pending" | "approved" | "spam" | "deleted";

	type AdminComment = {
		id: string;
		pagePath: string;
		parentId: string | null;
		nickname: string;
		email: string | null;
		emailHash: string | null;
		website: string | null;
		content: string;
		status: CommentStatus;
		createdAt: string;
		updatedAt: string;
	};

	type AdminCommentsResponse = {
		ok: boolean;
		comments?: AdminComment[];
		message?: string;
	};

	type StatusUpdateResponse = {
		ok: boolean;
		status?: CommentStatus;
		message?: string;
	};

	type AdminRoot = HTMLElement & {
		dataset: DOMStringMap & {
			adminReady?: string;
			apiBaseUrl?: string;
		};
	};

	const STORAGE_KEY = "mizuki-admin-comments-token";

	function formatLocalTime(value: string) {
		const date = new Date(value);
		return Number.isNaN(date.getTime())
			? value
			: date.toLocaleString(undefined, {
					year: "numeric",
					month: "2-digit",
					day: "2-digit",
					hour: "2-digit",
					minute: "2-digit",
				});
	}

	function getElements(root: AdminRoot) {
		return {
			form: root.querySelector<HTMLFormElement>("[data-token-form]"),
			tokenInput: root.querySelector<HTMLInputElement>("[data-token-input]"),
			feedback: root.querySelector<HTMLElement>("[data-feedback]"),
			grid: root.querySelector<HTMLElement>("[data-comment-grid]"),
			filters: Array.from(
				root.querySelectorAll<HTMLButtonElement>("[data-status-filter]"),
			),
		};
	}

	function setFeedback(root: AdminRoot, message: string, tone: "error" | "success" | "" = "") {
		const { feedback } = getElements(root);
		if (!feedback) return;
		feedback.textContent = message;
		feedback.dataset.tone = tone;
	}

	function getSavedToken() {
		return window.localStorage.getItem(STORAGE_KEY) ?? "";
	}

	function setActiveFilter(root: AdminRoot, status: string) {
		const { filters } = getElements(root);
		for (const filter of filters) {
			filter.classList.toggle("is-active", filter.dataset.statusFilter === status);
		}
	}

	function renderState(root: AdminRoot, message: string) {
		const { grid } = getElements(root);
		if (!grid) return;
		grid.replaceChildren();
		const card = document.createElement("div");
		card.className = "empty-card";
		card.textContent = message;
		grid.append(card);
	}

	function createMeta(label: string, value: string) {
		const item = document.createElement("div");
		item.className = "meta-item";
		const term = document.createElement("dt");
		term.textContent = label;
		const detail = document.createElement("dd");
		detail.textContent = value || "-";
		item.append(term, detail);
		return item;
	}

	function createActionButton(
		root: AdminRoot,
		comment: AdminComment,
		status: CommentStatus,
		label: string,
	) {
		const button = document.createElement("button");
		button.type = "button";
		button.dataset.status = status;
		button.textContent = label;
		button.disabled = comment.status === status;
		button.addEventListener("click", () => {
			void updateStatus(root, comment.id, status);
		});
		return button;
	}

	function renderComments(root: AdminRoot, comments: AdminComment[]) {
		const { grid } = getElements(root);
		if (!grid) return;

		grid.replaceChildren();
		if (comments.length === 0) {
			renderState(root, "暂无评论");
			return;
		}

		for (const comment of comments) {
			const card = document.createElement("article");
			card.className = "comment-card";

			const heading = document.createElement("div");
			heading.className = "comment-heading";
			const author = document.createElement("h2");
			author.textContent = comment.nickname;
			const badge = document.createElement("span");
			badge.className = `status-badge status-${comment.status}`;
			badge.textContent = comment.status;
			heading.append(author, badge);

			const meta = document.createElement("dl");
			meta.className = "meta-grid";
			meta.append(
				createMeta("邮箱", comment.email ?? "-"),
				createMeta("网站", comment.website ?? "-"),
				createMeta("页面路径", comment.pagePath),
				createMeta("创建时间", formatLocalTime(comment.createdAt)),
				createMeta("parentId", comment.parentId ?? "-"),
				createMeta("status", comment.status),
			);

			const content = document.createElement("p");
			content.className = "comment-content";
			content.textContent = comment.content;

			const actions = document.createElement("div");
			actions.className = "action-row";
			actions.append(
				createActionButton(root, comment, "approved", "通过"),
				createActionButton(root, comment, "pending", "待审核"),
				createActionButton(root, comment, "spam", "标记垃圾"),
				createActionButton(root, comment, "deleted", "删除"),
			);

			card.append(heading, meta, content, actions);
			grid.append(card);
		}
	}

	async function loadComments(root: AdminRoot, status = "") {
		const token = getSavedToken();
		if (!token) {
			renderState(root, "请先输入 ADMIN_TOKEN");
			return;
		}

		setFeedback(root, "");
		renderState(root, "加载中...");

		const apiBaseUrl = root.dataset.apiBaseUrl ?? "";
		const url = new URL(`${apiBaseUrl}/api/admin/comments`);
		if (status) url.searchParams.set("status", status);

		try {
			const response = await fetch(url, {
				headers: {
					Accept: "application/json",
					Authorization: `Bearer ${token}`,
				},
			});
			const data = (await response.json()) as AdminCommentsResponse;
			if (!response.ok || !data.ok || !Array.isArray(data.comments)) {
				throw new Error(data.message || "评论加载失败");
			}
			renderComments(root, data.comments);
		} catch (error) {
			renderState(root, "评论加载失败");
			setFeedback(
				root,
				error instanceof Error ? error.message : "评论加载失败",
				"error",
			);
		}
	}

	async function updateStatus(root: AdminRoot, id: string, status: CommentStatus) {
		const token = getSavedToken();
		if (!token) {
			setFeedback(root, "请先输入 ADMIN_TOKEN", "error");
			return;
		}

		try {
			const response = await fetch(
				`${root.dataset.apiBaseUrl ?? ""}/api/admin/comments/${encodeURIComponent(id)}/status`,
				{
					method: "PATCH",
					headers: {
						"Content-Type": "application/json",
						Accept: "application/json",
						Authorization: `Bearer ${token}`,
					},
					body: JSON.stringify({ status }),
				},
			);
			const data = (await response.json()) as StatusUpdateResponse;
			if (!response.ok || !data.ok) {
				throw new Error(data.message || "状态更新失败");
			}
			setFeedback(root, "状态已更新", "success");
			const activeStatus =
				getElements(root).filters.find((filter) =>
					filter.classList.contains("is-active"),
				)?.dataset.statusFilter ?? "";
			await loadComments(root, activeStatus);
		} catch (error) {
			setFeedback(
				root,
				error instanceof Error ? error.message : "状态更新失败",
				"error",
			);
		}
	}

	function initAdminComments() {
		document.querySelectorAll<AdminRoot>("[data-admin-comments]").forEach((root) => {
			if (root.dataset.adminReady === "true") return;
			root.dataset.adminReady = "true";

			const { form, tokenInput, filters } = getElements(root);
			if (tokenInput) tokenInput.value = getSavedToken();

			form?.addEventListener("submit", (event) => {
				event.preventDefault();
				const token = tokenInput?.value.trim() ?? "";
				window.localStorage.setItem(STORAGE_KEY, token);
				setFeedback(root, token ? "Token 已保存" : "Token 已清空", token ? "success" : "");
				void loadComments(root);
			});

			for (const filter of filters) {
				filter.addEventListener("click", () => {
					const status = filter.dataset.statusFilter ?? "";
					setActiveFilter(root, status);
					void loadComments(root, status);
				});
			}

			void loadComments(root);
		});
	}

	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", initAdminComments, { once: true });
	} else {
		initAdminComments();
	}
	document.addEventListener("astro:page-load", initAdminComments);
	document.addEventListener("mizuki:page:loaded", initAdminComments);
</script>

<style>
	.admin-comments-page {
		display: grid;
		gap: 1rem;
	}
	.admin-header h1 {
		color: rgba(0, 0, 0, 0.9);
		font-size: 1.5rem;
		font-weight: 700;
	}
	.admin-kicker {
		margin-bottom: 0.2rem;
		color: rgba(0, 0, 0, 0.48);
		font-size: 0.8rem;
		font-weight: 700;
		text-transform: uppercase;
	}
	.token-panel,
	.comment-card,
	.empty-card {
		border: 1px solid color-mix(in oklab, var(--primary) 16%, transparent);
		border-radius: 0.85rem;
		background:
			linear-gradient(135deg, rgba(255, 255, 255, 0.55), rgba(255, 255, 255, 0.28)),
			color-mix(in oklab, var(--card-bg-transparent) 92%, transparent);
		box-shadow:
			0 12px 30px rgba(0, 0, 0, 0.06),
			inset 0 1px 0 rgba(255, 255, 255, 0.24);
	}
	.token-panel {
		display: grid;
		gap: 0.5rem;
		padding: 1rem;
	}
	.token-panel label {
		color: rgba(0, 0, 0, 0.72);
		font-size: 0.875rem;
	}
	.token-row {
		display: flex;
		gap: 0.65rem;
	}
	.token-row input {
		min-width: 0;
		flex: 1;
		border: 1px solid rgba(0, 0, 0, 0.1);
		border-radius: 0.75rem;
		background: rgba(255, 255, 255, 0.58);
		padding: 0.72rem 0.85rem;
		color: rgba(0, 0, 0, 0.84);
	}
	.token-row button,
	.filter-row button,
	.action-row button {
		border: 1px solid color-mix(in oklab, var(--primary) 36%, transparent);
		border-radius: 0.75rem;
		padding: 0.58rem 0.8rem;
		font-weight: 700;
	}
	.token-row button {
		background: var(--primary);
		color: white;
	}
	.filter-row,
	.action-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.55rem;
	}
	.filter-row button,
	.action-row button {
		background: color-mix(in oklab, var(--primary) 12%, white);
		color: color-mix(in oklab, var(--primary) 72%, black);
	}
	.filter-row button.is-active {
		background: var(--primary);
		color: white;
	}
	.action-row button:disabled {
		cursor: not-allowed;
		opacity: 0.55;
	}
	.feedback {
		min-height: 1.25rem;
		color: rgba(0, 0, 0, 0.52);
		font-size: 0.875rem;
	}
	.feedback[data-tone="error"] {
		color: #b42318;
	}
	.feedback[data-tone="success"] {
		color: #067647;
	}
	.comment-grid {
		display: grid;
		gap: 0.9rem;
	}
	.comment-card {
		display: grid;
		gap: 0.85rem;
		padding: 1rem;
	}
	.comment-heading {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
	}
	.comment-heading h2 {
		min-width: 0;
		color: rgba(0, 0, 0, 0.88);
		font-size: 1rem;
		font-weight: 700;
		overflow-wrap: anywhere;
	}
	.status-badge {
		border-radius: 999px;
		padding: 0.24rem 0.56rem;
		font-size: 0.78rem;
		font-weight: 700;
	}
	.status-approved {
		background: rgba(6, 118, 71, 0.12);
		color: #067647;
	}
	.status-pending {
		background: rgba(181, 71, 8, 0.12);
		color: #b54708;
	}
	.status-spam,
	.status-deleted {
		background: rgba(180, 35, 24, 0.12);
		color: #b42318;
	}
	.meta-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.65rem 1rem;
	}
	.meta-item {
		min-width: 0;
	}
	.meta-item dt {
		color: rgba(0, 0, 0, 0.48);
		font-size: 0.78rem;
	}
	.meta-item dd {
		color: rgba(0, 0, 0, 0.78);
		font-size: 0.9rem;
		overflow-wrap: anywhere;
	}
	.comment-content {
		white-space: pre-wrap;
		overflow-wrap: anywhere;
		line-height: 1.75;
		color: rgba(0, 0, 0, 0.8);
	}
	.empty-card {
		padding: 1rem;
		color: rgba(0, 0, 0, 0.78);
	}
	:global(:root.dark) .admin-header h1,
	:global(:root.dark) .comment-heading h2 {
		color: rgba(255, 255, 255, 0.94);
	}
	:global(:root.dark) .admin-kicker,
	:global(:root.dark) .feedback,
	:global(:root.dark) .meta-item dt {
		color: rgba(255, 255, 255, 0.58);
	}
	:global(:root.dark) .token-panel,
	:global(:root.dark) .comment-card,
	:global(:root.dark) .empty-card {
		border-color: rgba(255, 255, 255, 0.08);
		background:
			linear-gradient(135deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.035)),
			color-mix(in oklab, var(--card-bg-transparent) 92%, transparent);
		box-shadow:
			0 16px 36px rgba(0, 0, 0, 0.24),
			inset 0 1px 0 rgba(255, 255, 255, 0.08);
	}
	:global(:root.dark) .token-panel label,
	:global(:root.dark) .meta-item dd,
	:global(:root.dark) .comment-content,
	:global(:root.dark) .empty-card {
		color: rgba(255, 255, 255, 0.82);
	}
	:global(:root.dark) .token-row input {
		border-color: rgba(255, 255, 255, 0.12);
		background: rgba(255, 255, 255, 0.06);
		color: rgba(255, 255, 255, 0.88);
	}
	:global(:root.dark) .filter-row button,
	:global(:root.dark) .action-row button {
		background: color-mix(in oklab, var(--primary) 22%, transparent);
		color: color-mix(in oklab, var(--primary) 28%, white);
	}
	@media (max-width: 768px) {
		.token-row {
			flex-direction: column;
		}
		.token-row button {
			width: 100%;
		}
		.meta-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
